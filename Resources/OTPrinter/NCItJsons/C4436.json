  "definitions": [
    {
      "definition": "A carcinoma that arises from the intrahepatic bile ducts, the hepatic ducts, or the common bile duct distal to the insertion of the cystic duct. The vast majority of tumors are adenocarcinomas.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A malignant neoplasm arising from/comprising cells resembling those of bile ducts.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "A rare type of cancer that develops in cells that line the bile ducts in the liver. Cancer that forms where the right and left ducts meet is called Klatskin tumor.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
