  "definitions": [
    {
      "definition": "A disease in which certain cells of the lymph system (called T lymphocytes) become cancer.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "A non-Hodgkin lymphoma of T-cell lineage. It includes the T lymphoblastic lymphoma and the mature T- and NK-cell lymphomas.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
