  "definitions": [
    {
      "definition": "A rare, invasive colon adenocarcinoma characterized by the presence of sheets of malignant epithelial cells with vesicular nuclei, prominent nucleoli, and abundant eosinophilic cytoplasm.  It usually has a favorable prognosis.",
      "type": "DEFINITION",
      "source": "NCI"
    }
