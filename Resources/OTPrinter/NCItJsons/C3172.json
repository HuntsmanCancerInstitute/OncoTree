  "definitions": [
    {
      "definition": "A clonal proliferation of myeloid cells and their precursors in the bone marrow, peripheral blood, and spleen. When the proliferating cells are immature myeloid cells and myeloblasts, it is called acute myeloid leukemia. When the proliferating myeloid cells are neutrophils, it is called chronic myelogenous leukemia.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A progressive, proliferative disease of blood cells, originating from immature granulocytes.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    }
  ],
