  "definitions": [
    {
      "definition": "A phyllodes tumor of the breast characterized by infiltrative margins and a sarcomatous stromal component.  The sarcomatous stroma usually displays features of fibrosarcoma.  Liposarcomatous, osteosarcomatous, or rhabdomyosarcomatous elements may also be present.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
