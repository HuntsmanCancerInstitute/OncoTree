  "definitions": [
    {
      "definition": "A clonal neoplasm of small B-lymphocytes, lymphoplasmacytoid cells, and plasma cells involving the bone marrow, lymph nodes, and the spleen. The majority of patients have a serum IgM paraprotein.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A malignant neoplasm composed of lymphocytes (B-cells), lymphoplasmacytoid cells, and plasma cells.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    }
  ],
