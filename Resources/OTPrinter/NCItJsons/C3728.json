  "definitions": [
    {
      "definition": "A malignant embryonal neoplasm that arises from the liver. It occurs almost exclusively in infants, although isolated cases in older children and adults have been reported. Microscopically,  it consists of either epithelial or epithelial and mesenchymal components.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A malignant liver neoplasm composed of immature hepatocytic elements.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "A malignant liver tumor that arises from precursors of hepatocytes. It occurs almost exclusively in infants. The lungs are the most common site of metastasis.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "A type of liver tumor that occurs in infants and children.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
