  "definitions": [
    {
      "definition": "A WHO grade 2 or 3 pineal parenchymal neoplasm of intermediate-grade malignancy, affecting all ages.  It is composed of diffuse sheets or large lobules of uniform cells with mild to moderate nuclear atypia and low to moderate level mitotic activity.  (Adapted from WHO)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
