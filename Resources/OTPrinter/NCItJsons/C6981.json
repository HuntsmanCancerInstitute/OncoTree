  "definitions": [
    {
      "definition": "A squamous cell carcinoma that arises from the penis.  It is characterized by a papillary growth pattern, hyperkeratosis and parakeratosis.  Koilocytotic atypia is present.  Human papillomavirus types 16 and 6 have been identified in some cases.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
