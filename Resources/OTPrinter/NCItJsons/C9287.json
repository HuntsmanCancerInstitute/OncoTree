  "definitions": [
    {
      "definition": "Acute myeloid leukemia characterized by the presence of abnormal bone marrow eosinophils and the characteristic cytogenetic abnormality inv(16)(p13.1q22) or  t(16;16)(p13.1;q22), which results in the expression of the fusion protein CBFB-MYH11. This is seen in 7-9% of children with AML.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "An acute myeloid leukemia with monocytic and granulocytic differentiation and the presence of a characteristically abnormal eosinophil component in the bone marrow.  This type of acute myeloid leukemia has a favorable prognosis.  (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
