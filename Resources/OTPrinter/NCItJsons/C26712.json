  "definitions": [
    {
      "definition": "A type of cancer that begins in cells that line certain internal organs and produce mucin (the main component of mucus).",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "An adenocarcinoma comprising neoplastic glandular cells containing intracytoplasmic mucin.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "An invasive adenocarcinoma composed of malignant glandular cells that contain intracytoplasmic mucin. Often, the infiltrating glandular structures are associated with mucoid stromal formation. It may arise from the large and small intestine, appendix, stomach, lung, ovary, breast, corpus uteri, cervix, vagina, and salivary gland.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
