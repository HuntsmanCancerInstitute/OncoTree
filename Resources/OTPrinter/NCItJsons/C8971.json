  "definitions": [
    {
      "definition": "A poorly circumscribed morphologic variant of rhabdomyosarcoma that shows primitive skeletal muscle differentiation in any stage of myogenesis.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A soft tissue tumor that is most common in infants and young children. It begins in muscles, usually in the head, neck, or genitourinary tract.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
