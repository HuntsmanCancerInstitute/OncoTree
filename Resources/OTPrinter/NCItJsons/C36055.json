  "definitions": [
    {
      "definition": "A term referring to acute myeloid leukemias which show variant translocations involving the RARA gene. The variant fusion partners include NUMA1, ZBTB16 (PLZF), STAT5B, and NPM1. These leukemias often have the morphologic features of acute promyelocytic leukemia.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "A term that refers to acute promyelocytic leukemias that show variant translocations involving the RARA gene. The variant fusion partners include NUMA1, ZBTB16, STAT5B, and NPM1.",
      "type": "DEFINITION",
      "source": "NCI"
    }
