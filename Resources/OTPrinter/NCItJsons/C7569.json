  "definitions": [
    {
      "definition": "A diverse group of carcinomas of the thymus gland, previously known as thymoma type C.  It includes morphologic variants derived from purely epithelial cells, as well as from cells with neuroendocrine differentiation.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A rare type of thymus gland cancer. It usually spreads, has a high risk of recurrence, and has a poor survival rate. Thymic carcinoma is divided into subtypes, depending on the types of cells in which the cancer began.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
