  "definitions": [
    {
      "definition": "A progressive, proliferative disease of blood cells, originating from immature monocytes.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "An acute myeloid leukemia in which the majority of monocytic cells are promonocytes.  (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
