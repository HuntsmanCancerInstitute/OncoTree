  "definitions": [
    {
      "definition": "A clear, transparent, sometimes faintly yellow and slightly opalescent fluid that is collected from the tissues throughout the body, flows in the lymphatic vessels (through the lymph nodes), and is eventually added to the venous blood circulation. Lymph consists of a clear liquid portion, varying numbers of white blood cells (chiefly lymphocytes), and a few red blood cells.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A clear, transparent, sometimes faintly yellow and slightly opalescent fluid that is collected from the tissues throughout the body, flows in the lymphatic vessels (through the lymph nodes), and is eventually added to the venous blood circulation. Lymph consists of a clear liquid portion, varying numbers of white blood cells (chiefly lymphocytes), and a few red blood cells. (NCI)",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "The clear fluid that travels through the lymphatic system and carries cells that help fight infections and other diseases.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
