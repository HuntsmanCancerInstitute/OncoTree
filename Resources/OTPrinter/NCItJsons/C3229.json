  "definitions": [
    {
      "definition": "A benign or malignant neoplasm that affects the meninges.  The majority of the neoplasms arise from meningothelial cells and are called meningiomas.  Non-meningothelial cell neoplasms include mesenchymal, non-meningothelial tumors, hemangiopericytomas, and melanocytic lesions.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
