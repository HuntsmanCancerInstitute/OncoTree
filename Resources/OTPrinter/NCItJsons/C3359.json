  "definitions": [
    {
      "definition": "A malignant mesenchymal neoplasm arising from skeletal muscle.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "A malignant neoplasm arising from skeletal myocytes.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "A rare aggressive malignant mesenchymal neoplasm that arises from striated (skeletal or cardiac) muscle cells. It usually occurs in children and young adults.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "Cancer that forms in the soft tissues in a type of muscle called striated muscle. Rhabdomyosarcoma can occur anywhere in the body.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
