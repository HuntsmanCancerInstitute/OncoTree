  "definitions": [
    {
      "definition": "A term that refers to a large and heterogeneous group of invasive breast carcinomas that cannot be classified morphologically as any of the special histological types. (WHO 2019)",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "The most common type of invasive breast cancer. It starts in the cells that line the milk ducts in the breast, grows outside the ducts, and often spreads to the lymph nodes.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
