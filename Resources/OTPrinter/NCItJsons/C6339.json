  "definitions": [
    {
      "definition": "A malignant mesenchymal neoplasm arising from the wall of the uterine corpus (uterine body).  The most representative examples are leiomyosarcoma and endometrial stromal sarcoma.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A rare type of uterine cancer that forms in muscle or other tissues of the uterus (the small, hollow, pear-shaped organ in a woman's pelvis in which a fetus develops). It usually occurs after menopause. The two main types are leiomyosarcoma (cancer that begins in smooth muscle cells) and endometrial stromal sarcoma (cancer that begins in connective tissue cells).",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
