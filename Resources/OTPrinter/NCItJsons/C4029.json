  "definitions": [
    {
      "definition": "An adenocarcinoma arising from the endocervical glandular epithelium. It is classified as either human papillomavirus-related or human papillomavirus-independent adenocarcinoma. Histologic variants include usual-type, mucinous, mesonephric, serous, clear cell, and endometrioid adenocarcinoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
