  ],
  "definitions": [
    {
      "definition": "A primary cutaneous T-cell lymphoproliferative disorder that presents as an acral (peripheral) lesion. It is composed of CD8-positive neoplastic T-lymphocytes. It is usually localized to a single site and has an indolent clinical course. Local or more extensive recurrences have been described in a minority of patients.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
