  "definitions": [
    {
      "definition": "A conventional osteosarcoma characterized by the presence of spindle shaped cells.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A malignant fibrosarcoma characterized by pleomorphic cells intermixed with variable amounts of collagenous matrix.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    }
