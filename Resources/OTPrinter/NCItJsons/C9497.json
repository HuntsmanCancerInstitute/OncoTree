  "definitions": [
    {
      "definition": "A rare malignant embryonal neoplasm characterized by the presence of small cells which resemble the cells of classic medulloblastoma and a minor population of melanin-forming neuroepithelial cells.  It usually has an unfavorable clinical course.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
