  "definitions": [
    {
      "definition": "B lymphoblastic leukemia/lymphoma characterized by a gene-expression profile similar to that of BCR-ABL1-positive B lymphoblastic leukemia/lymphoma, absence of the pathognomonic BCR-ABL1 rearrangement, alterations of lymphoid transcription factor genes, and a poor outcome.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
