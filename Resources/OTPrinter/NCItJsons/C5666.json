  "definitions": [
    {
      "definition": "A rare usually indolent lung carcinoma characterized by a cribiform and tubular pattern and the presence of glandular epithelial cells.  Clinical symptoms include shortness of breath, cough, wheeze, hemopytsis and chest pain.",
      "type": "DEFINITION",
      "source": "NCI"
    }
