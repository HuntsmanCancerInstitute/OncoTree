  "definitions": [
    {
      "definition": "Cervical adenocarcinoma not associated with human papillomavirus infection and characterized by the presence of clear and hobnail cells. It is associated with in utero exposure to diethylstilbestrol (DES).",
      "type": "DEFINITION",
      "source": "NCI"
    }
