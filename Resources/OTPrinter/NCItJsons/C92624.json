  "definitions": [
    {
      "definition": "A rare tumor that arises from the pineal region and affects adults.  It is characterized by the presence of neuroepithelial cells and a papillary architecture.  Electron microscopic studies suggest ependymal differentiation.  The clinical course is variable.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
