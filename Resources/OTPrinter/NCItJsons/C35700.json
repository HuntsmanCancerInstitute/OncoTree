  "definitions": [
    {
      "definition": "A locally aggressive carcinoma that arises from the salivary glands, predominantly the parotid gland. It is characterized by the presence of a malignant cellular infiltrate exhibiting myoepithelial differentiation. Patients usually present with a painless mass.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
