  "definitions": [
    {
      "definition": "A rare, slow-growing neuroepithelial neoplasm of uncertain origin affecting adults. It is located in the third ventricle. It is characterized by the presence of epithelioid cells which express GFAP, and mucinous stroma which contains lymphoplasmacytic infiltrates.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
