  "definitions": [
    {
      "definition": "A well-differentiated neuroendocrine neoplasm of low, intermediate, or high grade arising from the digestive system. It is characterized by the presence of cells with features similar to those of the normal endocrine cells of the digestive system. The neoplastic cells express immunohistochemical evidence of neuroendocrine differentiation and hormones.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
