  "definitions": [
    {
      "definition": "An indolent (slow-growing) type of non-Hodgkin lymphoma marked by abnormal levels of IgM antibodies in the blood and an enlarged liver, spleen, or lymph nodes.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "Lymphoplasmacytic lymphoma associated with bone marrow involvement and IgM monoclonal gammopathy.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
