  "definitions": [
    {
      "definition": "A rare carcinoma that arises from the cervix. It is characterized by the presence of cystic spaces surrounded by palisaded epithelial cells. The cystic spaces contain eosinophilic hyaline material or mucin. Nuclear pleomorphism, necrotic changes, and a high mitotic rate are also present.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
