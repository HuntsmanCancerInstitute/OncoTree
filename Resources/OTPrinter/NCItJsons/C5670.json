  "definitions": [
    {
      "definition": "A neoplasm with neuroendocrine differentiation that arises from the lung.  This category includes typical carcinoid tumor, atypical carcinoid tumor, small cell carcinoma, large cell neuroendocrine carcinoma, and combined carcinoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
