  "definitions": [
    {
      "definition": "A non-Hodgkin lymphoma which is associated with breast implants, and consists of large anaplastic cells. The WHO diagnostic criteria for BIA-ALCL includes positive expression of CD30 (CD30+) and negativity for anaplastic lymphoma kinase (ALK-).",
      "type": "ALT_DEFINITION",
      "source": "FDA",
      "qualifiers": [
        {
          "type": "attribution",
          "value": "CDRH"
        }
      ]
    },
    {
      "definition": "A rare anaplastic large cell lymphoma that develops in individuals with breast implants. It usually presents as an accumulation of seroma fluid between the implant and the surrounding fibrous capsule. The median interval from the time of the implant to the development of lymphoma is approximately 10 years.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
