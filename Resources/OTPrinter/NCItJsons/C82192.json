  "definitions": [
    {
      "definition": "A rare mixed phenotype acute leukemia in which the blasts carry the chromosomal translocation t(9;22)(q34.1;q11.2) that results in BCR-ABL1 gene fusion. The prognosis is usually unfavorable.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
