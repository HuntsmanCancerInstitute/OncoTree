  "definitions": [
    {
      "definition": "A gestational trophoblastic disorder in which there is no embryo or normal placental tissue and the chorionic villi are hydropic.",
      "type": "DEFINITION",
      "source": "NCI",
      "qualifiers": [
        {
          "type": "attribution",
          "value": "NICHD"
        }
      ]
    },
    {
      "definition": "A placental disorder where the majority of the chorionic villi are hydropic.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    }
