  "definitions": [
    {
      "definition": "A benign, WHO grade I cerebellar mass, which occurs in young adults and is composed of dysplastic ganglion cells.  It is the major CNS manifestation of Cowden disease, an autosomal dominant condition that causes a variety of hamartomas and neoplasms.",
      "type": "DEFINITION",
      "source": "NCI",
      "qualifiers": [
        {
          "type": "attribution",
          "value": "from WHO"
        }
      ]
    }
  ],
