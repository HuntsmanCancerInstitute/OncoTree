  "definitions": [
    {
      "definition": "An adenocarcinoma arising from the stomach.  Microscopically, it is characterized by the presence of a diffuse infiltrate, composed of individual adenocarcinoma cells or groups of adenocarcinoma cells in a fibrous or mucoid stroma.  Many cells contain mucin droplets, producing a signet-ring configuration.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
