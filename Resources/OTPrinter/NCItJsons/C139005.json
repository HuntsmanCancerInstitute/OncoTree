  "definitions": [
    {
      "definition": "A group of node-based peripheral T-cell lymphomas with phenotypic features of T follicular helper (TFH) cells. This category includes the following: follicular helper T-cell lymphoma, angioimmunoblastic-type; follicular helper T-cell lymphoma, follicular-type; and follicular helper T-cell lymphoma, not otherwise specified.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
