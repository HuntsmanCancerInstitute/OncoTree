  "definitions": [
    {
      "definition": "A rare, highly vascular tumor that is composed of abundant capillaries and stromal cells. It arises from the central nervous system and infrequently other sites. It is a slow growing tumor with a low risk of metastasis, despite its benign histological features.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
