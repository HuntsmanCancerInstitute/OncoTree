  "definitions": [
    {
      "definition": "A malignant neoplasm composed of cells resembling histiocytes.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "An aggressive malignant neoplasm with a poor response to therapy, usually presenting as stage III/IV disease. It is characterized by the presence of neoplastic cells with morphologic and immunophenotypic characteristics similar to those seen in mature histiocytes.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
