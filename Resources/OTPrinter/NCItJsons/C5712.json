  "definitions": [
    {
      "definition": "A benign, non-metastasizing cystic epithelial neoplasm arising from the exocrine pancreas. It is composed of glycogen-rich epithelial cells that produce a watery fluid. Signs and symptoms include abdominal mass, abdominal pain, nausea, vomiting, and weight loss.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
