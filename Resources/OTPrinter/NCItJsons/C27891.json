  "definitions": [
    {
      "definition": "A group of renal cell carcinomas characterized by the presence of different translocations involving the chromosome Xp11.2. These translocations result in the creation of gene fusions involving the TFE3 gene. Patients are usually children and young adults. Morphologically, the malignant epithelial cells form papillary patterns.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
