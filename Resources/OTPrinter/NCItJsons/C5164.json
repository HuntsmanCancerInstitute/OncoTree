  "definitions": [
    {
      "definition": "A group of invasive breast carcinomas characterized by the presence of an adenocarcinomatous component which is admixed with a dominant component that is composed of squamous cells, spindle cells, or mesenchymal cells.",
      "type": "DEFINITION",
      "source": "NCI"
    }
