  "definitions": [
    {
      "definition": "A rare subtype of acute leukemia in which the blasts lack sufficient evidence to classify as myeloid or lymphoid, or they have morphologic and/or immunophenotypic characteristics of both myeloid and lymphoid cells. These subtypes account for less than 4% of cases of acute leukemia.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "An acute leukemia in which the blasts lack sufficient evidence to classify as myeloid or lymphoid or they have morphologic and/or immunophenotypic characteristics of both myeloid and lymphoid cells. (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
