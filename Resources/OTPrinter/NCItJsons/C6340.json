  "definitions": [
    {
      "definition": "An aggressive malignant smooth muscle neoplasm, arising from the uterine corpus.  It is characterized by a proliferation of neoplastic spindle cells.",
      "type": "DEFINITION",
      "source": "NCI"
    }
