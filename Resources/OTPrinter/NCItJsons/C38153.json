  "definitions": [
    {
      "definition": "Lymphangiomyomatosis involving the lungs and local lymph nodes.  Patients usually present with chylous pleural effusion.  The clinical course is variable.  Patients with resectable lesions usually have a favorable clinical outcome.  Patients with diffuse lesions usually have a progressive clinical course.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
