  "definitions": [
    {
      "definition": "A primary polypoid malignant neoplasm of the uterine corpus characterized by the presence of a sarcomatous mesenchymal component and a benign epithelial component. Patients usually present with abnormal vaginal bleeding. It is considered a low grade malignant neoplasm and may recur following resection.",
      "type": "DEFINITION",
      "source": "NCI"
    }
