  "definitions": [
    {
      "definition": "A rapidly growing rhabdomyosarcoma characterized by the presence of round cells with myoblastic differentiation and a fibrovascular stroma resembling an alveolar growth pattern. The tumor usually presents in the extremities.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A soft tissue tumor that is most common in older children and teenagers. It begins in embryonic muscle cells (cells that develop into muscles in the body). It can occur at many places in the body, but usually occurs in the trunk, arms, or legs.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
