  "definitions": [
    {
      "definition": "An epithelial neoplasm that arises from the ovary characterized by the presence of glandular or cystic spaces which contain atypical glandular epithelial cells resembling endometrial cells. The surrounding ovarian stroma is often fibrotic. There is no evidence of stromal invasion.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
