  "definitions": [
    {
      "definition": "A form of breast cancer in which the tumor grows from ducts beneath the nipple onto the surface of the nipple. Symptoms commonly include itching and burning and an eczema-like condition around the nipple, sometimes accompanied by oozing or bleeding.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "A malignant epithelial cellular proliferation characterized by the presence of atypical cells with large nuclei and abundant pale cytoplasm within the squamous epithelium of the nipple.  In almost all cases there is an underlying intraductal breast carcinoma or intraductal and invasive carcinoma.  The skin changes range from redness to eczematous appearance.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
