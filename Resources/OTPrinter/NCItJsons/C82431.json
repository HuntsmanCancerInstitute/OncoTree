  "definitions": [
    {
      "definition": "An acute myeloid leukemia (AML) with mutation of the nucleophosmin gene. It is usually associated with normal karyotype. It is seen in 8% of children with AML.",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "An acute myeloid leukemia with mutation of the nucleophosmin gene. It is usually associated with normal karyotype and frequently has myelomonocytic or monocytic features. It usually responds to induction therapy.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
