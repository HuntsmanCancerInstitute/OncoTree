  "definitions": [
    {
      "definition": "An aggressive, high grade adenocarcinoma that arises from the salivary glands. It usually affects elderly males and presents as a rapidly enlarging mass. It metastasizes to regional lymph nodes and distant anatomic sites.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
