  "definitions": [
    {
      "definition": "A rare neuroectodermal tumor originating from olfactory receptor cells in the sinonasal tract. In rare cases, it can be ectopic and originate from other sites such as the sellar region. Microscopically, it is characterized by neuroblastic differentiation with occasional formation of rosettes. If the tumor is not resected at an early stage, the prognosis is usually poor.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
