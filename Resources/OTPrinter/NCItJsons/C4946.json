  "definitions": [
    {
      "definition": "A follicular carcinoma of the thyroid gland, characterized by the presence of large cells with eosinophilic granular cytoplasm and pleomorphic nuclei with prominent, eosinophilic nucleoli.  The nuclear features that characterize the papillary carcinomas of the thyroid gland are absent.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
