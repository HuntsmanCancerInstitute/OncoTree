  "definitions": [
    {
      "definition": "A myelodysplastic syndrome characterized by bi-cytopenia or pancytopenia and dysplastic changes in 10% or more of the cells in two or more of the myeloid cell lines. (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    }
