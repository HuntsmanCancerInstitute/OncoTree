  "definitions": [
    {
      "definition": "An undifferentiated non-small cell lung carcinoma composed of large polygonal cells without evidence of glandular, squamous, or neuroendocrine differentiation.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "Lung cancer in which the cells are large and look abnormal when viewed under a microscope.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
