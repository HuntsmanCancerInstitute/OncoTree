  "definitions": [
    {
      "definition": "A WHO grade 2 neoplasm that arises from the brain parenchyma. Morphologically it is characterized by the presence of neoplastic uniform, round cells with neuronal differentiation. Unlike central neurocytoma, it does not involve the lateral ventricles. It usually affects young adults and has a favorable prognosis.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
