  "definitions": [
    {
      "definition": "A primary nodal B-cell non-Hodgkin lymphoma which morphologically resembles lymph nodes involved by marginal zone lymphomas of extranodal or splenic types, but without evidence of extranodal or splenic disease.  (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
