  "definitions": [
    {
      "definition": "A morphologic variant of chondrosarcoma arising from the bone.  It is characterized by the presence of malignant small round cells, biphasic growth pattern, and well differentiated hyaline cartilage. Clinical presentation includes pain and swelling.  The clinical course is aggressive, with local recurrences and distant metastases.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
