  "definitions": [
    {
      "definition": "A rare, slow-growing tumor that begins in oligodendrocytes (cells that cover and protect nerve cells in the brain and spinal cord).",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "A well-differentiated (WHO grade 2), diffusely infiltrating neuroglial tumor, typically located in the cerebral hemispheres.  It is composed predominantly of cells which morphologically resemble oligodendroglia. The neoplastic cells have rounded homogeneous nuclei and, on paraffin sections, a swollen, clear cytoplasm ('honeycomb' appearance). (Adapted from WHO)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
