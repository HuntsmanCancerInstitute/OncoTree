  "definitions": [
    {
      "definition": "A T-cell peripheral lymphoma morphologically indistinguishable from anaplastic large cell lymphoma, ALK-positive.  It is characterized by the absence of the translocation involving the ALK gene and lacks expression of ALK fusion protein.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
