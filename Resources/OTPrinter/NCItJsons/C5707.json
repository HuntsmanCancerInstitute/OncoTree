  "definitions": [
    {
      "definition": "A melanoma affecting the esophageal wall.  Melanoma in the esophagus is more commonly metastatic than primary.  Primary melanomas of the esophagus are polypoid and clinically aggressive.  (WHO, 2000)",
      "type": "DEFINITION",
      "source": "NCI"
    }
