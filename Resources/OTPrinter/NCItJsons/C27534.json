  "definitions": [
    {
      "definition": "An adenocarcinoma arising from the sweat glands. Most cases present as nodular lesions on the digits, usually in the hands. It is characterized by the presence of epithelial cells in the dermis forming nodules. Cystic structures containing papillary projections are also present. It may recur and metastasize, most commonly to the lungs.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
