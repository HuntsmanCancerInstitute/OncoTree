  "definitions": [
    {
      "definition": "Hematologic neoplasms characterized by the presence of t(8;9)(p22;p24.1) that results in PCM1-JAK2 fusion gene expression. It is associated with eosinophilia, bone marrow findings of left-shifted erythroid predominance, lymphoid aggregates, and often myelofibrosis. Rare cases present as T- or B-acute lymphoblastic leukemia.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
