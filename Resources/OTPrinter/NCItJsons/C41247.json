  "definitions": [
    {
      "definition": "A cystic epithelial neoplasm that arises from the exocrine pancreas and affects almost exclusively females. It is characterized by the presence of columnar mucin-producing epithelial cells and ovarian-type stroma formation. This category includes non-invasive pancreatic mucinous-cystic neoplasms (low-or high-grade) and pancreatic mucinous-cystic neoplasms with an associated invasive carcinoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
