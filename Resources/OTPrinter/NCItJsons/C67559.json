  "definitions": [
    {
      "definition": "A central nervous system neoplasm arising from the fourth ventricle. It is characterized by the presence of neurocytes forming pseudorosettes and astrocytes which contain Rosenthal fibers. Cytologic atypia is minimal.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
