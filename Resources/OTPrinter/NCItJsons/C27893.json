  "definitions": [
    {
      "definition": "A high-grade carcinoma that arises from the kidney. It is not a distinct clinicopathological entity and includes a diverse group of renal cell carcinomas that have been transformed from a lower to a higher grade.",
      "type": "DEFINITION",
      "source": "NCI"
    }
