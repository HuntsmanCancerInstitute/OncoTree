  "definitions": [
    {
      "definition": "A localized malignant neoplasm that arises in the bone. It is composed of clonal (malignant) plasma cells forming a tumor mass. The most commonly affected bones are the vertebrae, ribs, skull, pelvis, and femur.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
