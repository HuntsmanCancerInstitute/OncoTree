  "definitions": [
    {
      "definition": "A squamous cell carcinoma of the sinonasal tract characterized by a plexiform or ribbon-like growth pattern, cytological atypia, and lack of histological evidence of keratinization.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
