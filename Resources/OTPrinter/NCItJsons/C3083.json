  "definitions": [
    {
      "definition": "A clonal disorder characterized by the secretion of a truncated gamma chain.  In most cases, it is associated with morphologic changes also seen in lymphoplasmacytic lymphomas, but the clinical course is typically more aggressive than in lymphoplasmacytic lymphoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
