  "definitions": [
    {
      "definition": "A carcinoma that arises from the pancreas showing both ductal and squamous differentiation.  The squamous component should represent at least 30% of the malignant cellular infiltrate.  The prognosis is usually worse than that of ductal adenocarcinoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
