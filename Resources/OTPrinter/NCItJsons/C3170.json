  "definitions": [
    {
      "definition": "A progressive, proliferative disease of blood cells, originating from immature megakaryocytes.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "An acute myeloid leukemia in which at least 50% of the blasts are of megakaryocytic lineage. (WHO, 2001)",
      "type": "ALT_DEFINITION",
      "source": "NICHD"
    },
    {
      "definition": "An acute myeloid leukemia in which at least 50% of the blasts are of megakaryocytic lineage. (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
