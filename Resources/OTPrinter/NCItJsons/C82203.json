  "definitions": [
    {
      "definition": "A rare mixed phenotype acute leukemia in which the blasts carry a translocation between the KMT2A gene at 11q23.3 and another gene partner. The prognosis is usually unfavorable.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
