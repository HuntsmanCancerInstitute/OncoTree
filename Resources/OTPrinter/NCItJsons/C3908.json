  "definitions": [
    {
      "definition": "A carcinoma arising from the ampulla of Vater.  The vast majority of cases are adenocarcinomas.  Signs and symptoms include jaundice, abdominal pain, anorexia, nausea, vomiting, and weight loss.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "Cancer that forms in the ampulla of Vater (an enlargement of the ducts from the liver and pancreas where they join and enter the small intestine). Symptoms include jaundice, abdominal pain, nausea, vomiting, and weight loss.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
