  "definitions": [
    {
      "definition": "A benign, malignant, or borderline biphasic neoplasm that arises from the breast parenchyma. It is characterized by the presence of an epithelial and a mesenchymal (stromal) component. The typical examples are fibroadenoma and phyllodes tumor.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
