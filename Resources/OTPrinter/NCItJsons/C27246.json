  "definitions": [
    {
      "definition": "An aggressive malignant tumor arising from trophoblastic cells in the uterus during pregnancy.  Approximately half of the cases develop from a complete hydatidiform mole.  There is often marked elevation of human chorionic gonadotropin (hCG) in the blood.  Choriocarcinomas disseminate rapidly through the hematogenous route; the lungs are most frequently affected.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
