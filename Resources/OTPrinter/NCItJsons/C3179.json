  "definitions": [
    {
      "definition": "A disease in which too many neutrophils (a type of white blood cell) are found in the blood. The extra neutrophils may cause the spleen and liver to become enlarged. Chronic neutrophilic leukemia may stay the same for many years or it may progress quickly to acute leukemia.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "A rare chronic myeloproliferative neoplasm characterized by neutrophilic leukocytosis.  There is no detectable Philadelphia chromosome or BCR/ABL fusion gene.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
