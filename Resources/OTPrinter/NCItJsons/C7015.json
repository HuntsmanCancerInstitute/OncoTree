  "definitions": [
    {
      "definition": "A central nervous system teratoma characterized by the presence of a malignant component. The malignant component most often is sarcomatous (rhabdomyosarcoma or undifferentiated sarcoma) or carcinomatous (squamous cell carcinoma or adenocarcinoma).",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
