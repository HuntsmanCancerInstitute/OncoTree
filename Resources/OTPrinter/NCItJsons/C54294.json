  "definitions": [
    {
      "definition": "A rare, highly aggressive carcinoma that arises from the sinonasal tract.  It is characterized by the presence of small to medium size malignant cells.  The prognosis is poor.",
      "type": "DEFINITION",
      "source": "NCI"
    }
