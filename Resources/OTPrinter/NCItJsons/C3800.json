  "definitions": [
    {
      "definition": "A low-grade malignant blood vessel neoplasm characterized by the presence of epithelioid endothelial cells. The neoplastic cells are arranged in cords and nests that are embedded in a myxoid to hyalinized stroma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
