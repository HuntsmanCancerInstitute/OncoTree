  "definitions": [
    {
      "definition": "An osteosarcoma usually arising from the metaphysis of long bones. It is characterized by the presence of a cystic architecture with blood-filled spaces. The prognosis is similar to that of conventional osteosarcoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
