  "definitions": [
    {
      "definition": "A carcinoma arising from the squamous cells of the epidermis.  Skin squamous cell carcinoma is most commonly found on sun-exposed areas.  The majority of the tumors are well-differentiated.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
