  "definitions": [
    {
      "definition": "An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the stomach and is composed of malignant small cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
