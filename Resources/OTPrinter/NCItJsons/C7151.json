  "definitions": [
    {
      "definition": "A mature B-cell neoplasm characterized by the deposition of immunoglobulin in tissues, resulting in impaired organ function. It includes the following entities: primary amyloidosis, heavy chain deposition disease, and light chain deposition disease.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
