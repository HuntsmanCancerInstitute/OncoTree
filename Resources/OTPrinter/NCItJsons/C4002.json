  "definitions": [
    {
      "definition": "A localized malignant neoplasm arising in an extraosseous site. It is composed of clonal (malignant) plasma cells forming a tumor mass. It most frequently involves the oropharynx, nasopharynx, sinuses, and larynx.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
