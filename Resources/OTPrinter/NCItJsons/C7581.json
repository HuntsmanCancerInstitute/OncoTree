  "definitions": [
    {
      "definition": "A low-grade adenocarcinoma with ductal differentiation, arising from the sweat glands. It presents as a scar usually in the face. It is characterized by the formation of small ducts and it frequently involves nerves and perineural spaces.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
