  "definitions": [
    {
      "definition": "Acute erythroid leukemia characterized by the presence of immature erythroid cells in the bone marrow (at least 80% of the cellular component), without evidence of a significant myeloblastic cell population present.",
      "type": "DEFINITION",
      "source": "NCI"
    }
