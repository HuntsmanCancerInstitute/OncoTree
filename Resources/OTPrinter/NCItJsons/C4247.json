  "definitions": [
    {
      "definition": "A malignant neoplasm composed of a fibroblastic and a histiocytic component.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    },
    {
      "definition": "A soft tissue sarcoma that usually occurs in the limbs, most commonly the legs, and may also occur in the abdomen.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    },
    {
      "definition": "An undifferentiated soft tissue sarcoma characterized by the presence of a pleomorphic malignant cellular infiltrate.  It is also known as malignant fibrous histiocytoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
