  "definitions": [
    {
      "definition": "An adenocarcinoma of the stomach arising on a background of intestinal metaplasia.  Microscopically, it is characterized by a glandular pattern and it closely resembles a colonic adenocarcinoma.",
      "type": "DEFINITION",
      "source": "NCI"
    }
