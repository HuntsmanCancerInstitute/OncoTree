  "definitions": [
    {
      "definition": "A chronic myeloproliferative neoplasm characterized by bone marrow fibrosis, proliferation of atypical megakaryocytes and granulocytes in the bone marrow, anemia, splenomegaly, and extramedullary hematopoiesis. (WHO, 2001)",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A progressive, chronic disease in which the bone marrow is replaced by fibrous tissue and blood is made in organs such as the liver and the spleen, instead of in the bone marrow. This disease is marked by an enlarged spleen and progressive anemia.",
      "type": "ALT_DEFINITION",
      "source": "NCI-GLOSS"
    }
  ],
