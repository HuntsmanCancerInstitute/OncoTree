  "definitions": [
    {
      "definition": "A rare, aggressive, poorly differentiated, non-small cell lung carcinoma characterized by the presence of a sarcomatoid component often associated with giant cell differentiation. There is a male to female ratio of 4:1.  Clinical symptoms include cough, hemoptysis, chest pain, progressive dyspnea and fever secondary to recurrent pneumonia. Cigarette smoking is a major risk factor.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
