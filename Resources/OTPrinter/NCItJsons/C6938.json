  "definitions": [
    {
      "definition": "A carcinoma that arises from the sweat glands. Representative examples include porocarcinoma, hidradenocarcinoma, microcystic adnexal carcinoma, skin adenoid cystic carcinoma, apocrine carcinoma, and digital papillary adenocarcinoma.",
      "type": "DEFINITION",
      "source": "NCI"
    },
    {
      "definition": "A malignant neoplasm arising from sweat glands.",
      "type": "ALT_DEFINITION",
      "source": "CDISC"
    }
  ],
