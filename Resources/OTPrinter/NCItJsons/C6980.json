  "definitions": [
    {
      "definition": "An aggressive, human papillomavirus-related squamous cell carcinoma that arises from the penis.  It is characterized by the presence of nests of small malignant cells.  The malignant cells tend to invade deeply into the adjacent tissues.  Comedo-type necrosis is often present.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
