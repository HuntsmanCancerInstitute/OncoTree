  "definitions": [
    {
      "definition": "A usually slow growing, subcutaneous nodular neoplasm arising from myopericytes.  It is composed of myoid cells arranged in a perivascular growth pattern.  The vast majority of cases have a benign clinical course.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
