  "definitions": [
    {
      "definition": "A usually aggressive large B-cell lymphoma characterized by the presence of monomorphic immunoblast-like neoplastic B-lymphocytes in a sinusoidal growth pattern.  The neoplastic B-lymphocytes express the ALK kinase but they lack the 2;5 translocation.",
      "type": "DEFINITION",
      "source": "NCI"
    }
  ],
