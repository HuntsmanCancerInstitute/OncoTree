  "definitions": [
    {
      "definition": "A poorly differentiated variant of adenosquamous carcinoma that arises from the cervix. It is characterized by the presence of large malignant cells with ground glass cytoplasm and stromal eosinophilic infiltrates.",
      "type": "DEFINITION",
      "source": "NCI"
    }
